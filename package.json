{
  "name": "occam-verify-cli",
  "author": "James Smith",
  "version": "1.0.1026",
  "license": "MIT, Anti-996",
  "homepage": "https://github.com/djalbat/occam-verify-cli",
  "description": "Occam's Verifier",
  "repository": {
    "type": "git",
    "url": "https://github.com/djalbat/occam-verify-cli"
  },
  "dependencies": {
    "argumentative": "^2.0.47",
    "necessary": "^17.2.10",
    "occam-furtle": "^3.0.284",
    "occam-languages": "^0.0.261",
    "occam-model": "^1.0.530",
    "occam-nominal": "^1.0.189",
    "occam-server": "^7.0.30"
  },
  "devDependencies": {
    "@swc/core": "1.13.20",
    "watchful-cli": "^1.7.98"
  },
  "scripts": {
    "clean": "rm -rf ./lib",
    "watchful": "watchful -m --transpiler=swc --source-directory=./src --lib-directory=./lib --pause=100",
    "batch": "npm run watchful batch --",
    "batch-debug": "npm run watchful batch -- --debug",
    "incremental": "npm run watchful incremental --",
    "incremental-debug": "npm run watchful incremental -- --debug",
    "build": "npm run clean && npm run batch",
    "build-debug": "npm run clean && npm run batch-debug",
    "watch": "npm run clean && npm run batch && npm run incremental",
    "watch-debug": "npm run clean && npm run batch-debug && npm run incremental-debug"
  },
  "main": "./lib/index.js",
  "files": [
    "src",
    "lib",
    "verify.js"
  ],
  "bin": {
    "verify": "./verify.js"
  }
}
